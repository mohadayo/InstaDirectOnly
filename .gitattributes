# .gitattributes for InstaDirectOnly (iOS / Swift)
#
# 目的:
#   1. すべてのテキストファイルの行末を LF に正規化し、
#      Windows / macOS / Linux の混在チェックアウトでも安定した差分を維持する。
#   2. バイナリファイル (画像・フォント等) を明示的にバイナリとして扱う。
#   3. Xcode プロジェクトファイルは行末を保持し、ツールによる書き換えを避ける。
#   4. GitHub Linguist の言語判定に必要なヒントを付与する。

# ------------------------------------------------------------------------------
# デフォルト: すべてのテキストファイルを自動判定し、リポジトリ内では LF で保存
# ------------------------------------------------------------------------------
* text=auto eol=lf

# ------------------------------------------------------------------------------
# Swift ソースコード
# ------------------------------------------------------------------------------
*.swift    text eol=lf diff=swift

# ------------------------------------------------------------------------------
# Xcode プロジェクトファイル (Xcode が管理するのでツールによる正規化を避ける)
# ------------------------------------------------------------------------------
*.pbxproj           text eol=lf merge=union
*.xcworkspacedata   text eol=lf
*.xcscheme          text eol=lf
*.xcconfig          text eol=lf
*.plist             text eol=lf
*.storyboard        text eol=lf
*.xib               text eol=lf

# ------------------------------------------------------------------------------
# Swift Package Manager
# ------------------------------------------------------------------------------
Package.swift       text eol=lf
Package.resolved    text eol=lf

# ------------------------------------------------------------------------------
# ドキュメント / 設定
# ------------------------------------------------------------------------------
*.md                text eol=lf
*.yml               text eol=lf
*.yaml              text eol=lf
*.json              text eol=lf
*.sh                text eol=lf
Makefile            text eol=lf

# ------------------------------------------------------------------------------
# バイナリ / メディア (差分不要)
# ------------------------------------------------------------------------------
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.mov       binary
*.mp4       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.zip       binary
*.tar.gz    binary

# ------------------------------------------------------------------------------
# GitHub Linguist ヒント
#   自動生成物 / ベンダー物を言語統計から除外する。
# ------------------------------------------------------------------------------
*.pbxproj                 linguist-generated=true
InstaDirectOnly.xcodeproj/** linguist-generated=true
