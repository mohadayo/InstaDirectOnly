# EditorConfig helps maintain consistent coding styles across editors and IDEs.
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Swift (Xcode default: 4 spaces)
[*.swift]
indent_style = space
indent_size = 4

# Xcode project files - do not trim, Xcode manages them
[*.{pbxproj,xcworkspacedata,xcscheme,plist,storyboard,xib}]
trim_trailing_whitespace = false

# YAML / JSON
[*.{yml,yaml,json}]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Makefile requires tabs for recipes
[{Makefile,makefile,GNUmakefile}]
indent_style = tab

# Markdown: keep trailing spaces (two-space line break)
[*.md]
trim_trailing_whitespace = false
